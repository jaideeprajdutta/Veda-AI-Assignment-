# ---------- API ----------
PORT=4000
WORKER_PORT=4100
WEB_ORIGIN=http://localhost:3000

# ---------- MongoDB Atlas ----------
# Your Atlas SRV connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/vedaai?retryWrites=true&w=majority

# ---------- Redis (BullMQ + cache + socket.io adapter) ----------
REDIS_URL=redis://localhost:6379

# ---------- LLM ----------
# which provider the worker uses: gemini | mock
LLM_PROVIDER=gemini

# Gemini (free key: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# ---------- Frontend (Next public) ----------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
