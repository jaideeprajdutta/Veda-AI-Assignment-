{
  "name": "vedaai",
  "version": "1.0.0",
  "private": true,
  "description": "VedaAI - AI Assessment Creator",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose down",
    "dev:api": "npm run dev --workspace @vedaai/api",
    "dev:worker": "npm run worker --workspace @vedaai/api",
    "dev:web": "npm run dev --workspace @vedaai/web",
    "dev": "concurrently -n api,worker,web -c blue,magenta,green \"npm:dev:api\" \"npm:dev:worker\" \"npm:dev:web\"",
    "build": "npm run build --workspace @vedaai/shared && npm run build --workspace @vedaai/api && npm run build --workspace @vedaai/web",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
